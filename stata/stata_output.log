. 
. * --- All-cause exit, both cohorts ---

. 
.   foreach cohort in 2018 2019 {
  2. 
.       display as text _newline "=== Cohort `cohort' - all-cause exit ==="
  3. 
.       preserve
  4. 
.           keep if RegYear == `cohort'
  5. 
.           drop if missing(NACE_section)
  6. 
.           drop if NACE_section == 16 | NACE_section == 21
  7. 
.           stset surv_time, failure(failed)
  8. 
.           stcox ln_aksje i.emp_cat i.zip_cat i.Chair_gender_cat i.SFACT_bin i.NACE_section
  9. 
.           estimates store cox_`cohort'_all
 10. 
.       restore
 11. 
.   }

