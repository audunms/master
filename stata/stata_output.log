. * ============================================

. 
. * Table D31: LOO sensitivity (all-cause exit) - sustainability HR by excluded NACE section

. 
. * ============================================

. 
. quietly levelsof NACE_section if !missing(NACE_section) & NACE_section != 16 & NACE_section != 21, local(naces)

. 
. display as text "{hline 75}"
---------------------------------------------------------------------------

. 
. display as text %-50s "Excluded NACE section" %12s "HR" %12s "p-value"
Excluded NACE section                                       HR     p-value

. 
. display as text "{hline 75}"
---------------------------------------------------------------------------

. 
. quietly {
. 
. foreach n of local naces {
. 
. preserve
. 
. drop if missing(NACE_section)
. 
. drop if NACE_section == 16 | NACE_section == 21
. 
. drop if NACE_section == `n'
. 
. local lbl : label (NACE_section) `n'
. 
. stset surv_time, failure(failed)
. 
. stcox ln_aksje i.emp_cat i.zip_cat i.Chair_gender_cat i.SFACT_bin i.NACE_section i.RegYear
. 
. local hr = exp(_b[1.SFACT_bin])
. 
. local p = 2 * (1 - normal(abs(_b[1.SFACT_bin] / _se[1.SFACT_bin])))
. 
. noisily display as text %-50s "`lbl'" %12.3f `hr' %12.3f `p'
. 
. restore
. 
. }
