replace Y4SRev = salg2023 if RegYear == 2019
gen Y5SRev = salg2023 if RegYear == 2018
replace Y5SRev = salg2024 if RegYear == 2019

* Relative-year total operating revenue
gen Y1Rev = driftsinnt2019 if RegYear == 2018
replace Y1Rev = driftsinnt2020 if RegYear == 2019
gen Y2Rev = driftsinnt2020 if RegYear == 2018
