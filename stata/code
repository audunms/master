* Relative-year sales revenue
gen Y1SRev = salg2019 if RegYear == 2018
replace Y1SRev = salg2020 if RegYear == 2019
gen Y2SRev = salg2020 if RegYear == 2018
replace Y2SRev = salg2021 if RegYear == 2019
gen Y3SRev = salg2021 if RegYear == 2018
