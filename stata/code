forvalues i = 1/5 {
    gen ln_Y`i'SRev = ln(Y`i'SRev) if Y`i'SRev > 0
    gen ln_Y`i'Rev = ln(Y`i'Rev) if Y`i'Rev > 0
}
gen srev_growth = (Y5SRev - Y1SRev) / Y1SRev if Y1SRev > 0
