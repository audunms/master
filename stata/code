* ============================================
* Extract HR + 95 % CI for plotting
* ============================================
tempname memhold
postfile `memhold' step str30 label HR lb ub pval using sfact_evolution_strict.dta, replace
local models   M1 M2 M3 M4a M4b M5 M6 M7
local labels `" "(1) SFACT only" "(2) +NACE" "(3) +Year" "(4a) +Zip" "(4b) +Gender" "(5) +Zip+Gender" "(6) +Equity" "(7) Full" "'
local i = 1
foreach m of local models {
    estimates restore `m'
    local lab : word `i' of `labels'
    scalar hr = exp(_b[1.SFACT_bin])
    scalar lb = exp(_b[1.SFACT_bin] - 1.96 * _se[1.SFACT_bin])
    scalar ub = exp(_b[1.SFACT_bin] + 1.96 * _se[1.SFACT_bin])
    scalar pv = 2 * (1 - normal(abs(_b[1.SFACT_bin] / _se[1.SFACT_bin])))
    post `memhold' (`i') ("`lab'") (hr) (lb) (ub) (pv)
    local ++i
}
postclose `memhold'
use sfact_evolution_strict.dta, clear
list, sep(0) noobs
twoway (rcap lb ub step, lcolor(navy)) (scatter HR step, mcolor(navy) msize(medlarge)), yline(1, lcolor(gs10) lpattern(dash)) ytitle("Hazard ratio (SFACT_bin = 1)") xtitle("") xlabel(1 "M1" 2 "M2: +NACE" 3 "M3: +Year" 4 "M4a: +Zip" 5 "M4b: +Gender" 6 "M5: +Zip+Gender" 7 "M6: +Equity" 8 "M7: Full", angle(30)) title("SFACT_bin hazard ratio: nested Cox models, strict failure") legend(off)
graph export sfact_progression_strict.png, width(2000) replace
restore
