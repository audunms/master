* RAW DATA CHECKS
* ============================================
count
tab RegYear, missing

* ============================================
* VARIABLE CONSTRUCTION
* ============================================

destring NACE Aksjekapital Styrelederspostnr Fadrpostnr RegYear, replace force

foreach var in salg2024 salg2023 salg2022 salg2021 salg2020 salg2019 {
    capture destring `var', replace force
}
foreach var in driftsinnt2024 driftsinnt2023 driftsinnt2022 driftsinnt2021 driftsinnt2020 driftsinnt2019 {
    capture destring `var', replace force
}
foreach var in andredrift2024 andredrift2023 andredrift2022 andredrift2021 andredrift2020 andredrift2019 {
    capture destring `var', replace force
}

replace Antallansatte = "2" if strpos(Antallansatte, "til") > 0
destring Antallansatte, replace force

* Word counts
gen word_count_act = wordcount(Activity)
gen word_count_obj = wordcount(Company_objective)

* Survival and sustainability
replace NSR = "Active" if trim(NSR) == ""
encode NSR, gen(Status_cat)
gen Exists_bin = (missing(NSRY) | NSRY > 5)
gen failed = (Exists_bin == 0)
gen failed_strict = (failed == 1 & NSR != "Voluntarily discontinuation")
gen SFACT_bin = (SFACT > 0)
gen SFACT_high = (SFACT >= 2)
gen SFACT_sq = SFACT^2

* Registered share capital
gen ln_aksje = ln(Aksjekapital)

* Employee categories
gen emp_cat = .
replace emp_cat = 0 if Antallansatte == 0
replace emp_cat = 1 if inrange(Antallansatte, 1, 4)
replace emp_cat = 2 if inrange(Antallansatte, 5, 19)
replace emp_cat = 3 if Antallansatte >= 20 & !missing(Antallansatte)
label define emp_lbl 0 "No employees" 1 "1-4" 2 "5-19" 3 "20+"
label values emp_cat emp_lbl

* Zip code distance
gen zip_diff = abs(Styrelederspostnr - Fadrpostnr)
gen zip_cat = .
replace zip_cat = 0 if zip_diff == 0
replace zip_cat = 1 if zip_diff > 0 & zip_diff <= 100
replace zip_cat = 2 if zip_diff > 100 & zip_diff <= 1000
replace zip_cat = 3 if zip_diff > 1000 & !missing(zip_diff)
replace zip_cat = 4 if missing(zip_diff)
label define zip_lbl 0 "Same zip" 1 "Nearby (1-100)" 2 "Moderate (101-1000)" 3 "Far (1001+)" 4 "Missing"
label values zip_cat zip_lbl

* Board-chair gender
gen Chair_gender = ""
replace Chair_gender = "Male" if StyrelederM == "M" & StyrelederF == ""
replace Chair_gender = "Female" if StyrelederF == "F" & StyrelederM == ""
replace Chair_gender = "Uncertain" if (StyrelederM == "M" & StyrelederF == "F") | (StyrelederM == "" & StyrelederF == "")
encode Chair_gender, gen(Chair_gender_cat)

* NACE section mapping
gen NACE_section = .
replace NACE_section = 0  if NACE == 0
replace NACE_section = 1  if inrange(NACE, 1, 3)
replace NACE_section = 2  if inrange(NACE, 5, 9)
replace NACE_section = 3  if inrange(NACE, 10, 33)
replace NACE_section = 4  if NACE == 35
replace NACE_section = 5  if inrange(NACE, 36, 39)
replace NACE_section = 6  if inrange(NACE, 41, 43)
replace NACE_section = 7  if inrange(NACE, 45, 47)
replace NACE_section = 8  if inrange(NACE, 49, 53)
replace NACE_section = 9  if inrange(NACE, 55, 56)
replace NACE_section = 10 if inrange(NACE, 58, 60)
replace NACE_section = 11 if inrange(NACE, 61, 63)
replace NACE_section = 12 if inrange(NACE, 64, 66)
replace NACE_section = 13 if NACE == 68
replace NACE_section = 14 if inrange(NACE, 69, 75)
replace NACE_section = 15 if inrange(NACE, 77, 82)
replace NACE_section = 16 if NACE == 84
replace NACE_section = 17 if NACE == 85
replace NACE_section = 18 if inrange(NACE, 86, 88)
replace NACE_section = 19 if inrange(NACE, 90, 93)
replace NACE_section = 20 if inrange(NACE, 94, 96)
replace NACE_section = 21 if NACE == 97
